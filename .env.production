# Production Environment Configuration for OpenQA
# Copy this file to .env and fill in your values

# ============================================================================
# LLM CONFIGURATION (REQUIRED)
# ============================================================================
LLM_PROVIDER=openai                    # openai, anthropic, or ollama
OPENAI_API_KEY=                        # Your OpenAI API key
ANTHROPIC_API_KEY=                     # Your Anthropic API key (if using Claude)
OLLAMA_BASE_URL=http://localhost:11434 # Ollama URL (if self-hosting)
LLM_MODEL=gpt-4                        # Model to use

# ============================================================================
# TARGET APPLICATION (REQUIRED)
# ============================================================================
SAAS_URL=https://your-app.com          # URL of the application to test
SAAS_AUTH_TYPE=none                    # none, basic, or session
SAAS_USERNAME=                         # Username for auth (if needed)
SAAS_PASSWORD=                         # Password for auth (if needed)

# ============================================================================
# SECURITY (CRITICAL FOR PRODUCTION!)
# ============================================================================
# Generate a strong secret: openssl rand -hex 32
OPENQA_JWT_SECRET=                     # REQUIRED: JWT signing secret (min 32 chars)
OPENQA_AUTH_DISABLED=false             # NEVER set to true in production!
NODE_ENV=production                    # Always set to production

# ============================================================================
# WEB SERVER
# ============================================================================
WEB_PORT=4242                          # Port to listen on
WEB_HOST=0.0.0.0                       # Bind to all interfaces
CORS_ORIGINS=https://your-domain.com   # Allowed CORS origins (comma-separated)

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
AGENT_AUTO_START=false                 # Auto-start agent on launch (recommend false)
AGENT_INTERVAL_MS=3600000              # Run interval (1 hour = 3600000ms)
AGENT_MAX_ITERATIONS=20                # Max iterations per session

# ============================================================================
# GITHUB INTEGRATION (OPTIONAL)
# ============================================================================
GITHUB_TOKEN=                          # GitHub personal access token
GITHUB_OWNER=                          # Repository owner
GITHUB_REPO=                           # Repository name
GITHUB_BRANCH=main                     # Branch to monitor

# ============================================================================
# GIT LISTENER (OPTIONAL)
# ============================================================================
GIT_LISTENER_ENABLED=true              # Enable git merge/pipeline detection
GIT_POLL_INTERVAL_MS=60000             # Poll interval (1 minute)

# ============================================================================
# DATABASE
# ============================================================================
DB_PATH=/app/data/openqa.db            # Database file path (use /app/data in Docker)

# ============================================================================
# NOTIFICATIONS (OPTIONAL)
# ============================================================================
SLACK_WEBHOOK_URL=                     # Slack webhook for notifications
DISCORD_WEBHOOK_URL=                   # Discord webhook for notifications

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info                         # debug, info, warn, error
LOG_FORMAT=json                        # json or text
