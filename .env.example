# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gpt-4

# Target SaaS Application
SAAS_URL=https://your-app.com
SAAS_AUTH_TYPE=none
SAAS_USERNAME=
SAAS_PASSWORD=

# GitHub Integration (for issues + merge detection)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# GitLab Integration (alternative to GitHub)
GITLAB_TOKEN=
GITLAB_PROJECT=owner/repo
GITLAB_URL=https://gitlab.com
GITLAB_BRANCH=main

# Agent Configuration
AGENT_INTERVAL_MS=3600000
AGENT_MAX_ITERATIONS=20
AGENT_AUTO_START=true

# Git Listener (auto-test on merge/pipeline)
GIT_LISTENER_ENABLED=true
GIT_POLL_INTERVAL_MS=60000

# Web UI
WEB_PORT=3000
WEB_HOST=0.0.0.0

# Authentication (Dashboard Security)
# OPENQA_AUTH_DISABLED=false        # Set to 'true' ONLY for local dev (NEVER in production!)
# OPENQA_JWT_SECRET=                # Optional: custom JWT secret (auto-generated if not set)

# Database
DB_PATH=./data/openqa.db

# Notifications (Optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
