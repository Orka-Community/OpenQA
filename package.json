{
  "name": "@openqa/cli",
  "version": "1.0.3",
  "description": "Autonomous QA testing agent powered by Orka.js",
  "type": "module",
  "main": "./dist/cli/index.cjs",
  "bin": {
    "openqa": "./dist/cli/index.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "install.sh",
    "database/schema.sql",
    "database/schema-v2.sql"
  ],
  "scripts": {
    "dev": "tsx watch agent/index.ts",
    "build": "tsup",
    "start": "node dist/cli/index.js start",
    "prepublishOnly": "npm run build",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build"
  },
  "keywords": [
    "qa",
    "testing",
    "automation",
    "ai",
    "orkajs",
    "autonomous",
    "agent",
    "e2e",
    "playwright",
    "test-generation"
  ],
  "author": "Orka.js Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Orka-Community/OpenQA.git"
  },
  "homepage": "https://openqa.orkajs.com",
  "bugs": {
    "url": "https://github.com/Orka-Community/OpenQA/issues"
  },
  "dependencies": {
    "@orka-js/agent": "^1.0.0",
    "@orka-js/openai": "^1.0.0",
    "@orka-js/anthropic": "^1.0.0",
    "@orka-js/memory-store": "^1.0.0",
    "@orka-js/observability": "^1.0.0",
    "playwright": "^1.40.0",
    "@octokit/rest": "^20.0.2",
    "better-sqlite3": "^9.2.2",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "dotenv": "^16.3.1",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/better-sqlite3": "^7.6.8",
    "tsx": "^4.7.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
