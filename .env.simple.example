# ============================================
# OpenQA - Simple Docker Compose Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.simple.example .env

# ============================================
# REQUIRED: LLM Configuration
# ============================================
# Choose your LLM provider: openai, anthropic, or ollama
LLM_PROVIDER=openai

# OpenAI API Key (required if using OpenAI)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (required if using Anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama Base URL (required if using Ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Model to use (optional, defaults to gpt-4o for OpenAI)
# LLM_MODEL=gpt-4o

# ============================================
# REQUIRED: Security
# ============================================
# Generate a strong secret: openssl rand -hex 32
OPENQA_JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars

# ============================================
# REQUIRED: Target Application
# ============================================
# The SaaS application you want to test
SAAS_URL=https://your-app.com

# Authentication type: none, basic, or session
SAAS_AUTH_TYPE=none

# Credentials (if auth type is basic or session)
# SAAS_USERNAME=test@example.com
# SAAS_PASSWORD=testpassword

# ============================================
# OPTIONAL: GitHub Integration
# ============================================
# Auto-create issues for critical bugs
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_OWNER=your-username
# GITHUB_REPO=your-repo

# ============================================
# OPTIONAL: GitLab Integration
# ============================================
# GITLAB_TOKEN=glpat-your_token_here
# GITLAB_PROJECT=username/project
# GITLAB_URL=https://gitlab.com

# ============================================
# OPTIONAL: Agent Configuration
# ============================================
# How often to run tests (in milliseconds, default: 1 hour)
AGENT_INTERVAL_MS=3600000

# Maximum actions per test session
AGENT_MAX_ITERATIONS=20

# Auto-start testing on launch
AGENT_AUTO_START=true

# ============================================
# OPTIONAL: Port Configuration
# ============================================
# External port (accessible from outside, default: 4242)
# EXTERNAL_PORT=4242

# Internal port (inside container, default: 4242)
# Change this if port 3000 is already in use on your system
# INTERNAL_PORT=4242

# ============================================
# OPTIONAL: Notifications
# ============================================
# Slack webhook for notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook for notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
